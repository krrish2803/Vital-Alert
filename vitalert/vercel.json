{
  "installCommand": "pip install --break-system-packages -r requirements.txt",
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
